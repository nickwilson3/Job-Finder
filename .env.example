ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Web server secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEB_SECRET_KEY=change-me-generate-a-random-32-char-string

# Credential encryption key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=generate-with-fernet-generate-key

# Google Drive OAuth — uses inputs/oauth_credentials.json (same file as CLI).
# Add the redirect URI below to authorized redirect URIs in Google Cloud Console.
# Defaults to localhost if not set. Change when deploying to a real domain.
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
